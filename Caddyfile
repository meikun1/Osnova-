# Минимальный стартовый Caddyfile. Бот сам дописывает блоки для каждого
# привязанного пользователем домена (через admin API :2019).
{
    # admin API нужен боту для горячего reload без перезапуска контейнера.
    admin 0.0.0.0:2019
    email {$CADDY_ACME_EMAIL}
}

:80 {
    redir https://{host}{uri} 301
}
