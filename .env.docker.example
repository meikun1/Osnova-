# Скопируй в .env рядом с docker-compose.yml и заполни значения:
#   cp .env.docker.example .env

# ============== ОБЯЗАТЕЛЬНО ==============

# Токен бота-менеджера из @BotFather.
MANAGER_BOT_TOKEN=123456789:PUT-YOUR-MANAGER-TOKEN

# Публичный IPv4 этого сервера (на него пойдут A-записи всех привязанных доменов).
DOMAIN_SERVER_IP=1.2.3.4

# Email для ACME-аккаунта в Let's Encrypt (используется Caddy при выпуске SSL).
CADDY_ACME_EMAIL=you@example.com

# Пароль локальной базы Postgres (придумай свой надёжный).
POSTGRES_PASSWORD=change-me-strong-password

# Длинная случайная строка для подписи кук мини-аппа.
# Сгенерировать:  openssl rand -hex 32
DIRECT_LINK_SESSION_SECRET=change-me-to-a-long-random-string

# ============== ОПЦИОНАЛЬНО ==============

# Базовый URL для мини-аппа (если есть). Без слеша на конце.
# MINIAPP_BASE_URL=https://example.com

# Куда увести пользователя после 3 неверных вводов кода.
# CODE_FAIL_REDIRECT_URL=https://t.me/+42777

# Имена БД и юзера в Postgres (можно не менять).
# POSTGRES_USER=osnova
# POSTGRES_DB=osnova
