# Скопируй в .env рядом с docker-compose.yml и заполни значения:
#   cp .env.docker.example .env

# Твой домен (DNS A-запись должна указывать на IP сервера).
# HTTPS-сертификат Caddy выпустит автоматически. БЕЗ https:// и без слэша.
DOMAIN=panel.example.com

# Токен бота-менеджера из @BotFather.
MANAGER_BOT_TOKEN=123456789:PUT-YOUR-MANAGER-TOKEN

# Пароль локальной базы Postgres (придумай свой надёжный).
POSTGRES_PASSWORD=change-me-strong-password
# Можно не менять:
POSTGRES_USER=osnova
POSTGRES_DB=osnova

# Длинная случайная строка для подписи кук мини-аппа.
# Сгенерировать:  openssl rand -hex 32
DIRECT_LINK_SESSION_SECRET=change-me-to-a-long-random-string

# Куда увести пользователя после 3 неверных вводов кода (можно оставить пустым).
CODE_FAIL_REDIRECT_URL=https://t.me/+42777
