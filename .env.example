# --- Бот-менеджер ---
# Токен самого менеджера из @BotFather (обязательно).
MANAGER_BOT_TOKEN=123456789:AaBbCc-PUT-YOUR-MANAGER-TOKEN

# --- База данных ---
# В проде на VPS используется PostgreSQL из docker-compose (сервис db),
# DATABASE_URL подставляется автоматически внутри compose. Для ручного
# запуска без docker:
# DATABASE_URL=postgresql://osnova:password@localhost:5432/osnova
# Если DATABASE_URL пуст — используется локальный SQLite-файл (BOT_MANAGER_DB).
DATABASE_URL=

# Путь к SQLite-файлу (используется, только если DATABASE_URL пуст).
BOT_MANAGER_DB=bot_manager.db

# --- Модуль «Прямая ссылка» ---
# Длинная случайная строка для подписи кук мини-аппа.
DIRECT_LINK_SESSION_SECRET=change-me-to-a-long-random-string
# Куда уводим юзера, зашедшего в мини-апп без правильной startapp-ссылки.
DIRECT_LINK_REDIRECT_URL=https://t.me/your_bot?startapp=profile
# Ссылка на мануал «как поставить мини-апп ссылку в @BotFather».
DIRECT_LINK_MANUAL_URL=https://telegra.ph/Ustanovka-ssylki-dlya-mini-app-02-11

# --- Веб-сервер мини-аппа ---
# RUN_WEB=1 чтобы поднять FastAPI вместе с менеджером (нужен HTTPS-домен).
RUN_WEB=1
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Публичный HTTPS-домен сервиса (без слэша в конце). Из него собирается
# Web App URL для @BotFather: <BASE>/app/<tg_id>.
MINIAPP_BASE_URL=https://your-domain.example
